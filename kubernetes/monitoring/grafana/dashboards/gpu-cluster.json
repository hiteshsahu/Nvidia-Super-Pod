{
  "__inputs": [],
  "__requires": [
    { "type": "grafana",    "id": "grafana",     "name": "Grafana",     "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus",  "name": "Prometheus",  "version": "1.0.0"  },
    { "type": "panel",      "id": "timeseries",  "name": "Time series", "version": ""       },
    { "type": "panel",      "id": "gauge",       "name": "Gauge",       "version": ""       },
    { "type": "panel",      "id": "stat",        "name": "Stat",        "version": ""       }
  ],
  "annotations": { "list": [] },
  "description": "NVIDIA SuperPod — GPU cluster metrics via DCGM Exporter",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["nvidia", "gpu", "dcgm", "superpod"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NVIDIA GPU Cluster",
  "uid": "nvidia-superpod-gpu",
  "version": 1,

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "pluginId": "prometheus",
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(DCGM_FI_DEV_GPU_UTIL, instance)",
        "query": { "query": "label_values(DCGM_FI_DEV_GPU_UTIL, instance)", "refId": "A" },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "gpu",
        "type": "query",
        "label": "GPU",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(DCGM_FI_DEV_GPU_UTIL{instance=~\"$instance\"}, gpu)",
        "query": { "query": "label_values(DCGM_FI_DEV_GPU_UTIL{instance=~\"$instance\"}, gpu)", "refId": "A" },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "title": "GPU Utilization",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 60   },
              { "color": "red",    "value": 90   }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "avg(DCGM_FI_DEV_GPU_UTIL{instance=~\"$instance\", gpu=~\"$gpu\"})",
          "legendFormat": "GPU Util %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "GPU Memory Used",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70   },
              { "color": "red",    "value": 90   }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "100 * avg(DCGM_FI_DEV_FB_USED{instance=~\"$instance\", gpu=~\"$gpu\"}) / (avg(DCGM_FI_DEV_FB_USED{instance=~\"$instance\", gpu=~\"$gpu\"}) + avg(DCGM_FI_DEV_FB_FREE{instance=~\"$instance\", gpu=~\"$gpu\"}))",
          "legendFormat": "VRAM Used %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "GPU Temperature",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70   },
              { "color": "red",    "value": 83   }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": true, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "avg(DCGM_FI_DEV_GPU_TEMP{instance=~\"$instance\", gpu=~\"$gpu\"})",
          "legendFormat": "Temperature °C",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "GPU Power Usage",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 120  },
              { "color": "red",    "value": 150  }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "area", "justifyMode": "auto" },
      "targets": [
        {
          "expr": "avg(DCGM_FI_DEV_POWER_USAGE{instance=~\"$instance\", gpu=~\"$gpu\"})",
          "legendFormat": "Power W",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "GPU Utilization Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL{instance=~\"$instance\", gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} util %",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_MEM_COPY_UTIL{instance=~\"$instance\", gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} mem-copy util %",
          "refId": "B"
        }
      ]
    },

    {
      "id": 6,
      "title": "GPU Memory (MiB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "mebibytes",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED{instance=~\"$instance\", gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} used",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_FB_FREE{instance=~\"$instance\", gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} free",
          "refId": "B"
        }
      ]
    },

    {
      "id": 7,
      "title": "GPU Temperature Over Time (°C)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70   },
              { "color": "red",    "value": 83   }
            ]
          }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP{instance=~\"$instance\", gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} temp",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "title": "GPU Power Over Time (W)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE{instance=~\"$instance\", gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} power",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "title": "SM & Memory Clocks (MHz)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "hertz",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_SM_CLOCK{instance=~\"$instance\", gpu=~\"$gpu\"} * 1e6",
          "legendFormat": "GPU {{gpu}} SM clock",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_MEM_CLOCK{instance=~\"$instance\", gpu=~\"$gpu\"} * 1e6",
          "legendFormat": "GPU {{gpu}} mem clock",
          "refId": "B"
        }
      ]
    },

    {
      "id": 10,
      "title": "PCIe Throughput (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(DCGM_FI_DEV_PCIE_TX_BYTES{instance=~\"$instance\", gpu=~\"$gpu\"}[1m])",
          "legendFormat": "GPU {{gpu}} TX",
          "refId": "A"
        },
        {
          "expr": "rate(DCGM_FI_DEV_PCIE_RX_BYTES{instance=~\"$instance\", gpu=~\"$gpu\"}[1m])",
          "legendFormat": "GPU {{gpu}} RX",
          "refId": "B"
        }
      ]
    },

    {
      "id": 11,
      "title": "ECC Errors (volatile)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 30, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1    }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "targets": [
        {
          "expr": "sum(DCGM_FI_DEV_ECC_SBE_VOL_TOTAL{instance=~\"$instance\", gpu=~\"$gpu\"})",
          "legendFormat": "Single-bit ECC errors",
          "refId": "A"
        },
        {
          "expr": "sum(DCGM_FI_DEV_ECC_DBE_VOL_TOTAL{instance=~\"$instance\", gpu=~\"$gpu\"})",
          "legendFormat": "Double-bit ECC errors",
          "refId": "B"
        }
      ]
    }

  ]
}
